# his_agent 部署配置

# 环境配置
SPRING_PROFILES_ACTIVE=prod

# 数据库配置
DB_HOST=192.168.1.50
DB_PORT=3306
DB_NAME=his_agent
DB_USER=hisagent
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis 配置
REDIS_HOST=192.168.1.60
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# 云端 AI 服务配置
XUNFEI_APP_ID=your_app_id
XUNFEI_API_KEY=your_api_key
XUNFEI_API_SECRET=your_api_secret

DASHSCOPE_API_KEY=your_dashscope_key

# HIS 系统集成
HIS_TOKEN_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----
HIS_BASE_URL=https://his.hospital.com
HIS_ALLOWED_ORIGINS=https://his.hospital.com,https://ehis.hospital.com

# 服务器配置
SERVER_PORT=8080
VIRTUAL_IP=192.168.1.100

# 备份配置
BACKUP_MODE=both  # local | remote | both
LOCAL_BACKUP_DIR=/backup/his_agent
REMOTE_BACKUP_ENABLED=true
REMOTE_BACKUP_TYPE=rsync  # rsync | sftp | s3
REMOTE_HOST=backup.hospital.com
REMOTE_USER=backup_user
REMOTE_PATH=/backup/his_agent
REMOTE_SSH_KEY=/etc/his_agent/backup_key
RETENTION_DAYS=30

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/his_agent/app.log
